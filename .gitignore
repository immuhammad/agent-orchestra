# per-checkout state (never migrated between machines/worktrees)
.worktrees/
.harness/state/
*.log
*.heartbeat
merge-watch-state
deferred-nudges
inbox/*/*.msg
inbox/*/*.ack
!inbox/*/.gitkeep
auto-resume-state.json
gatekeeper-alert-state.json
watch-flagged-dead

# dual-installed skill pack (bin/orc-install-skills dogfooded on this repo
# itself, e.g. for agy to review here) -- skills/ is the source, these are
# installed copies, never tracked
.claude/skills/
.agents/skills/

# per-project root files (issue #18 item 4) -- each project that adopts
# this harness copies these from templates/ and customizes its own copy;
# never tracked here (or in a consumer project). templates/*.md are the
# tracked reference/seed.
/AGENTS.md
/CLAUDE.md
/GEMINI.md
/review-protocol.md
