{
  "agy-guard": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "bash ../hooks/pane-state.sh busy < /dev/null"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ../lib/guard-quota-stop-agy.sh"
          },
          {
            "type": "command",
            "command": "bash ../lib/guard-agy.sh"
          },
          {
            "type": "command",
            "command": "bash ../lib/guard-room-branch-agy.sh"
          },
          {
            "type": "command",
            "command": "bash ../hooks/pane-state.sh busy < /dev/null"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash ../hooks/check-inbox-stop.sh < /dev/null"
      },
      {
        "type": "command",
        "command": "bash ../hooks/pane-state.sh idle < /dev/null"
      }
    ]
  }
}
