#!/bin/bash
# bin/orc — `orc up` builds the tmux control room from
# orchestrator.yaml. Extracted from career-ops-harness's .harness/orc.sh
# (epic #91a, issue #116) — ORC_SCRIPT_DIR now resolves to THIS repo's
# bin/, so pane commands and the liveness watchdog are anchored to
# ORC_LIB_DIR (this installation's lib/), not a `./.harness/...` path
# relative to whatever project cwd `orc up` happens to run from.
set -euo pipefail

ORC_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORC_LIB_DIR="$(cd "$ORC_SCRIPT_DIR/../lib" && pwd)"
# shellcheck source=../lib/orc-config.sh
source "$ORC_LIB_DIR/orc-config.sh"
# shellcheck source=../lib/room-branch-lib.sh
source "$ORC_LIB_DIR/room-branch-lib.sh"

# issue #18 item 7 + issue #19: derive the session name from THIS
# project's own orchestrator.yaml (orc_session_name, lib/orc-config.sh) so
# every clone-per-project control room gets its own session, not a shared
# hardcoded "harness" default -- ORC_SESSION still overrides outright.
ORC_SESSION="${ORC_SESSION:-$(orc_session_name "$(basename "$(pwd)")")}"

# orc_build_session -- everything `orc up` does except the final attach.
# Split out so tests can build a throwaway session, assert on it, and tear
# it down without this process getting replaced by `tmux attach` (exec).
orc_build_session() {
  local session="$ORC_SESSION"
  local project integration_branch orchestra_model implementer_model

  project="$(orc_get_scalar project)"
  project="${project:-$(basename "$(pwd)")}"
  integration_branch="$(orc_get_scalar integration_branch)"
  integration_branch="${integration_branch:-uat}"
  orchestra_model="$(orc_get_role_model orchestra)"
  orchestra_model="${orchestra_model:-opus}"
  implementer_model="$(orc_get_role_model implementer)"
  implementer_model="${implementer_model:-sonnet}"

  # issue #60 task C: refuse to build the control room on top of a checkout
  # that isn't on the integration branch -- the room's whole guard/dispatch
  # posture assumes panes operate against the shared integration branch, so
  # an accidental `orc up` from a stray feature-branch checkout would let
  # every pane quietly work against (and potentially push/PR from) the
  # wrong branch. "unknown" (detached HEAD, not a git repo, etc.) fails
  # closed the same as a real mismatch -- see room-branch-lib.sh. Two
  # escape hatches, both loud: a .harness/state/room-branch-override file
  # (its content is the human-readable reason, echoed here) or
  # ORC_ALLOW_UNMERGED_HARNESS=1 (tests/CI). Neither silences anything --
  # both still print a WARNING before proceeding.
  local room_state
  room_state="$(room_branch_state "$PWD")"
  if [ "$room_state" != "ok" ]; then
    if room_branch_override_active "$PWD"; then
      local override_reason
      override_reason="$(room_branch_override_reason "$PWD")"
      echo "orc: WARNING -- room branch $room_state (expected $integration_branch) -- override active, proceeding${override_reason:+ ($override_reason)}" >&2
    else
      echo "orc: REFUSE -- room branch $room_state (expected $integration_branch) -- no override present." \
        "Set ORC_ALLOW_UNMERGED_HARNESS=1 or write a reason to .harness/state/room-branch-override to proceed anyway." >&2
      return 1
    fi
  else
    # Only meaningful once we know we're actually ON the integration
    # branch -- a dirty tracked tree elsewhere isn't this check's concern.
    # Warn-only (never blocks): a WIP tracked change on the integration
    # branch is a footgun worth flagging, not a reason to refuse the room.
    if ! git -C "$PWD" diff --quiet HEAD -- 2>/dev/null || ! git -C "$PWD" diff --cached --quiet -- 2>/dev/null; then
      echo "orc: WARNING -- tracked working tree is dirty on integration branch ($integration_branch);" \
        "commit or stash before building the room." >&2
    fi
  fi

  # issue #22: assert the inbox dirs dispatch.sh actually writes to exist,
  # rather than trusting a hand-made layout -- a fresh clone-per-project
  # room used to have NO seeding step at all, so dispatch.sh's own
  # "no inbox for agent" guard hard-failed the first time anything dispatched
  # to an agent nobody had mkdir'd by hand. This is the live agent-name set
  # dispatch.sh's pane_for_agent/inbox_dir_name actually resolve to -- NOT
  # the `roles:` block above, whose keys (implementer/tester/reviewer) name
  # a different axis (per-role model config) than these fixed dispatch
  # identities. No legacy `copilot` dir: inbox_dir_name() now aliases it
  # INTO scribe/, so scribe/ alone is the one live physical directory.
  mkdir -p ./.harness/inbox/orchestra ./.harness/inbox/builder \
    ./.harness/inbox/agy ./.harness/inbox/scribe

  # issue #89: pane 3 (copilot/scribe) retired -- no recurring scribe
  # job remains after #85 (Builder writes PR bodies, watch.sh closes issues
  # mechanically), so scribe becomes an on-demand headless spawn
  # (dispatch.sh's assign/handoff to 'scribe', see nudge_agent) instead of a
  # standing pane. 5 panes now, not 6: orchestra, builder, agy, gatekeeper,
  # watch.
  #
  # issue #87: an even `tiled` 5-way split squeezed the 3 INTERACTIVE agent
  # panes (orchestra/builder/agy) down to ~18 rows on a real terminal --
  # not enough headroom for Claude Code's own status line + input box +
  # scrollback, so the input line gets squeezed to nothing ("no space to
  # type", live-reported repeatedly, and plausibly a contributor to the
  # separate nudge-stranding issues). gatekeeper/watch are read-only
  # dashboards that tolerate a short strip; the agent panes do not.
  # Reserves a fixed MONITOR_ROWS-tall bottom strip for gatekeeper+watch
  # and gives the agent row everything else, computed from the REAL
  # calling terminal's size via `tput` -- queried BEFORE any tmux client
  # exists, so this scales with whatever terminal `orc up` is actually run
  # from rather than a fixed cell count. ORC_TERM_COLS/ORC_TERM_LINES
  # override tput outright (tests: deterministic sizing without a real
  # controlling tty).
  #
  # Split TARGETS (0, then 0.0 twice, then 0.3) are unchanged from before
  # this fix -- empirically verified (tmux list-panes geometry) that this
  # exact sequence assigns indices 0/1/2/3/4 to top-left/top-mid/top-right/
  # bottom-left/bottom-right respectively, matching the index->role
  # contract (AGENTS.md: 0=orchestra 1=builder 2=agy 3=gatekeeper
  # 4=watch; dispatch.sh's pane_for_agent and gatekeeper-liveness's watch
  # target both hardcode these positions) -- only the SIZE arguments and
  # the trailing `select-layout tiled` (which discarded them) changed.
  #
  # Falls back to the ORIGINAL even-tiled layout, loudly (never silently),
  # on a terminal too small to give the agent row a floor of
  # MIN_AGENT_ROWS -- an `-l`/`-p` split size that would be non-positive is
  # a hard tmux error, not a soft clamp, so this must be decided BEFORE
  # issuing any split, not discovered from a failed command.
  # review round 2 (agy, CI-only failure on the Linux runner, reproduced
  # locally via Docker + Ubuntu 24.04's tmux 3.4): `-p <percent>` on
  # split-window fails outright ("size missing") on tmux 3.4, even though
  # it works fine on this dev machine's tmux 3.7b -- a real cross-version
  # behavior gap, not a typo. `-l <percent>%` and plain absolute `-l
  # <cells>` both work on every tmux version tested; switched to absolute
  # cell counts computed in shell (portable everywhere, no version-
  # dependent flag syntax at all).
  #
  # Also (round 2): `tput cols`/`tput lines` does NOT reliably fail when
  # stdout isn't a real terminal -- reproduced live, with TERM set (even
  # TERM=dumb) but no controlling tty, tput happily returns a plausible-
  # looking "80"/"24" fallback instead of erroring, which would otherwise
  # be trusted as "the actual client size" (this specific 80x24 case is
  # already caught by the row-count floor below, but that's incidental --
  # any other non-tty default that happened to number-check would not be
  # caught the same way). Gated explicitly: tput's numbers are only
  # trusted when stdout is a REAL tty; otherwise (and with no
  # ORC_TERM_COLS/LINES override) this always falls through to the loud
  # tiled fallback rather than gambling on what a non-tty default means.
  local term_cols term_lines monitor_rows=12 min_agent_rows=15 agent_rows
  local col_width half_width
  if [ -n "${ORC_TERM_COLS:-}" ] && [ -n "${ORC_TERM_LINES:-}" ]; then
    term_cols="$ORC_TERM_COLS"
    term_lines="$ORC_TERM_LINES"
  elif [ -t 1 ]; then
    term_cols="$(tput cols 2>/dev/null || echo 0)"
    term_lines="$(tput lines 2>/dev/null || echo 0)"
  else
    term_cols=0
    term_lines=0
  fi
  agent_rows=$(( term_lines - monitor_rows - 1 ))  # -1: the divider row between the agent row and the monitor row

  if [ "$term_cols" -gt 0 ] && [ "$term_lines" -gt 0 ] && [ "$agent_rows" -ge "$min_agent_rows" ]; then
    tmux new-session -d -s "$session" -n main -x "$term_cols" -y "$term_lines"
    tmux rename-window -t "$session:main" "control-room"
    tmux set -t "$session:0" pane-border-status top

    col_width=$(( term_cols / 3 ))
    half_width=$(( term_cols / 2 ))
    tmux split-window -v -l "$monitor_rows" -t "$session:0"
    tmux split-window -h -l "$col_width" -t "$session:0.0"
    tmux split-window -h -l "$col_width" -t "$session:0.0"
    tmux split-window -h -l "$half_width" -t "$session:0.3"
  else
    # review round 2: ALWAYS warn on this branch, even when the size is
    # totally unknown (0x0 -- no tty, no override) rather than merely
    # measured-too-small. An earlier draft only warned when term_lines was
    # a real positive number, silently skipping the message for the
    # unknown-size case -- exactly backwards from "loud, never silent"
    # (found live: no-tty + no-override took this branch with NO warning
    # at all).
    local size_desc="${term_cols}x${term_lines}"
    if [ "$term_cols" -le 0 ] || [ "$term_lines" -le 0 ]; then
      size_desc="unknown (no tty, no ORC_TERM_COLS/LINES override)"
    fi
    echo "orc: WARNING -- terminal size ${size_desc} -- too small (or undetectable) for the weighted agent-panes layout (need >= ${min_agent_rows} rows for the agent panes after reserving ${monitor_rows} for the monitor row) -- falling back to the even tiled layout. Agent panes will be short; resize your terminal and restart the room ('orc up' again after killing the session) for more headroom." >&2
    tmux new-session -d -s "$session" -n main
    tmux rename-window -t "$session:main" "control-room"
    tmux set -t "$session:0" pane-border-status top

    tmux split-window -v -t "$session:0"
    tmux split-window -h -t "$session:0.0"
    tmux split-window -h -t "$session:0.0"
    tmux split-window -h -t "$session:0.3"
    tmux select-layout -t "$session:0" tiled
  fi

  tmux select-pane -t "$session:0.0" -T "orchestra"
  tmux select-pane -t "$session:0.1" -T "builder"
  tmux select-pane -t "$session:0.2" -T "agy"
  tmux select-pane -t "$session:0.3" -T "gatekeeper"
  tmux select-pane -t "$session:0.4" -T "pr/budget watch"

  if [ "${ORC_SKIP_PANE_COMMANDS:-0}" != "1" ]; then
    # issue #50: ORC_ROLE=<role> prefixed on each pane's OWN launch command
    # (not `tmux send-keys ... export ...` as a separate step -- this must
    # be in the SAME process `claude` itself is exec'd from, so every hook
    # subprocess Claude Code spawns inherits it via ordinary environment
    # inheritance). hooks/check-handoff.sh reads this to gate the
    # handoff.md nag to Orchestra only -- a pane with no ORC_ROLE (a
    # session started outside this room) is correctly treated as unknown,
    # never nagged. agy isn't a Claude Code session (never fires Claude
    # Code hooks at all), so it gets no ORC_ROLE.
    tmux send-keys -t "$session:0.0" "ORC_ROLE=orchestra claude --model $orchestra_model --dangerously-skip-permissions" C-m
    tmux send-keys -t "$session:0.1" "ORC_ROLE=builder claude --model $implementer_model --dangerously-skip-permissions" C-m
    tmux send-keys -t "$session:0.2" 'agy --dangerously-skip-permissions' C-m
    # issue #105 Task 3: the supervisor respawns gatekeeper.sh with bounded
    # backoff if it ever exits, instead of leaving pane 3 with a dead
    # process until a human notices.
    tmux send-keys -t "$session:0.3" "$ORC_LIB_DIR/gatekeeper-supervisor.sh" C-m
    tmux send-keys -t "$session:0.4" "$ORC_LIB_DIR/watch.sh" C-m
  fi

  # Gatekeeper liveness watchdog: independent process, not a pane in
  # the main session, so a gatekeeper crash/hang can't also silence its own
  # warning. Log lands in THIS clone's own state dir (./.harness/state,
  # cwd-relative -- clone-per-project means there's no shared install to
  # clobber).
  #
  # issue #59: this used to be `nohup ... &`, which guard.sh correctly
  # fails closed on (nohup is an opaque executor it can't safely inspect
  # for a hidden write, same posture as eval/sudo/env -- see guard.sh's
  # leading_verb check) -- and did so MID-DRILL, after the other three
  # loops had already been killed, which is the worst possible moment to
  # discover a restart path doesn't work. A detached tmux session launched
  # the SAME way as the other three loops (gatekeeper-supervisor/watch, via
  # `tmux send-keys`) is fully inspectable and needs no special-casing here
  # -- `${session}-liveness` so two clone-per-project rooms never collide
  # on a shared session name (issue #19's own reasoning, applied here).
  # `-c "$PWD"` reproduces nohup's cwd-preserving behavior: gatekeeper-
  # liveness.sh resolves its project root from $PWD at launch time.
  if [ "${ORC_SKIP_LIVENESS:-0}" != "1" ]; then
    mkdir -p ./.harness/state
    local liveness_session="${session}-liveness"
    tmux kill-session -t "$liveness_session" 2>/dev/null || true
    tmux new-session -d -s "$liveness_session" -c "$PWD"
    tmux send-keys -t "$liveness_session" \
      "$ORC_LIB_DIR/gatekeeper-liveness.sh >> ./.harness/state/gatekeeper-liveness.log 2>&1" C-m
  fi

  # issue #18 item 5 (C1): seed merge-watch-state on a fresh room so
  # watch.sh's merge-watch doesn't replay comment+close on every already-
  # merged PR and fire a stale "PICK next" nudge. Idempotent (the helper
  # itself no-ops once the state file exists) and non-fatal (never aborts
  # `orc up` on a gh hiccup) -- safe to call unconditionally here, not just
  # on a literal first invocation.
  if [ "${ORC_SKIP_MERGE_WATCH_SEED:-0}" != "1" ]; then
    bash "$ORC_LIB_DIR/orc-seed-merge-watch.sh" || true
  fi

  # issue #10/#31: .claude/settings.json is a gitignored per-room artifact
  # -- a hand-assembled or drifted copy can silently omit a hook and
  # nothing catches it (exactly how the quota-stop-gate went un-wired for
  # this room's whole life). Non-fatal (a config problem `orc up` can't fix
  # itself shouldn't block the room from starting) but LOUD: the check
  # itself writes an explicit WARNING to stderr on any omission, so this
  # can't rot unseen the way #10 did.
  if [ "${ORC_SKIP_HOOK_WIRING_CHECK:-0}" != "1" ]; then
    bash "$ORC_LIB_DIR/check-hook-wiring.sh" ./.claude/settings.json || true
  fi

  tmux select-pane -t "$session:0.0"

  echo "orc up: project=$project integration_branch=$integration_branch" \
    "orchestra_model=$orchestra_model implementer_model=$implementer_model" \
    "protected_paths=$(orc_protected_paths | paste -sd, -)" >&2
}

orc_up() {
  local session="$ORC_SESSION"
  if tmux has-session -t "$session" 2>/dev/null; then
    exec tmux attach -t "$session"
  fi
  orc_build_session
  exec tmux attach -t "$session"
}

# BASH_SOURCE-guarded _main, same pattern as dispatch.sh/orc-worktree.sh:
# lets tests `source` this file for orc_build_session without triggering
# the interactive `orc up` path (and its `exec tmux attach`).
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  case "${1:-}" in
    up) orc_up ;;
    *)
      echo "usage: orc.sh up" >&2
      exit 1
      ;;
  esac
fi
