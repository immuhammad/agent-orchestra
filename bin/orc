#!/bin/bash
# bin/orc — `orc up` builds the tmux control room from
# orchestrator.yaml. Extracted from career-ops-harness's .harness/orc.sh
# (epic #91a, issue #116) — ORC_SCRIPT_DIR now resolves to THIS repo's
# bin/, so pane commands and the liveness watchdog are anchored to
# ORC_LIB_DIR (this installation's lib/), not a `./.harness/...` path
# relative to whatever project cwd `orc up` happens to run from.
set -euo pipefail

ORC_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORC_LIB_DIR="$(cd "$ORC_SCRIPT_DIR/../lib" && pwd)"
# shellcheck source=../lib/orc-config.sh
source "$ORC_LIB_DIR/orc-config.sh"
# shellcheck source=../lib/room-branch-lib.sh
source "$ORC_LIB_DIR/room-branch-lib.sh"
# shellcheck source=../lib/session-lifecycle.sh
source "$ORC_LIB_DIR/session-lifecycle.sh"

# issue #18 item 7 + issue #19: derive the session name from THIS
# project's own orchestrator.yaml (orc_session_name, lib/orc-config.sh) so
# every clone-per-project control room gets its own session, not a shared
# hardcoded "harness" default -- ORC_SESSION still overrides outright.
ORC_SESSION="${ORC_SESSION:-$(orc_session_name "$(basename "$(pwd)")")}"

# orc_build_session -- everything `orc up` does except the final attach.
# Split out so tests can build a throwaway session, assert on it, and tear
# it down without this process getting replaced by `tmux attach` (exec).
orc_build_session() {
  local session="$ORC_SESSION"

  # agy PR #133 round 1: "$session" is interpolated into tmux target
  # strings throughout this function and -- via the attach-snap hook
  # below -- into a command string /bin/sh executes when the hook fires:
  # a space word-splits that command, a single quote closes the sh
  # string early = arbitrary shell injection at hook-fire time.
  # orc_session_name sanitizes every derived name to this same charset,
  # so only a hand-set ORC_SESSION can ever get here -- refused LOUDLY
  # before any tmux call rather than trusted into an sh string.
  if ! [[ "$session" =~ ^[A-Za-z0-9_-]+$ ]]; then
    echo "orc: REFUSE -- session name '$session' contains characters outside [A-Za-z0-9_-]. Session names reach /bin/sh via the fallback's client-attached sizing hook and tmux target syntax everywhere else; fix orchestrator.yaml's 'project' (auto-sanitized) or the ORC_SESSION override (used verbatim)." >&2
    return 1
  fi

  local project integration_branch orchestra_model implementer_model

  project="$(orc_get_scalar project)"
  project="${project:-$(basename "$(pwd)")}"
  integration_branch="$(orc_get_scalar integration_branch)"
  integration_branch="${integration_branch:-uat}"
  orchestra_model="$(orc_get_role_model orchestra)"
  orchestra_model="${orchestra_model:-opus}"
  implementer_model="$(orc_get_role_model implementer)"
  implementer_model="${implementer_model:-sonnet}"

  # issue #60 task C: refuse to build the control room on top of a checkout
  # that isn't on the integration branch -- the room's whole guard/dispatch
  # posture assumes panes operate against the shared integration branch, so
  # an accidental `orc up` from a stray feature-branch checkout would let
  # every pane quietly work against (and potentially push/PR from) the
  # wrong branch. "unknown" (detached HEAD, not a git repo, etc.) fails
  # closed the same as a real mismatch -- see room-branch-lib.sh. Two
  # escape hatches, both loud: a .harness/state/room-branch-override file
  # (its content is the human-readable reason, echoed here) or
  # ORC_ALLOW_UNMERGED_HARNESS=1 (tests/CI). Neither silences anything --
  # both still print a WARNING before proceeding.
  local room_state
  room_state="$(room_branch_state "$PWD")"
  if [ "$room_state" != "ok" ]; then
    if room_branch_override_active "$PWD"; then
      local override_reason
      override_reason="$(room_branch_override_reason "$PWD")"
      echo "orc: WARNING -- room branch $room_state (expected $integration_branch) -- override active, proceeding${override_reason:+ ($override_reason)}" >&2
    else
      echo "orc: REFUSE -- room branch $room_state (expected $integration_branch) -- no override present." \
        "Set ORC_ALLOW_UNMERGED_HARNESS=1 or write a reason to .harness/state/room-branch-override to proceed anyway." >&2
      return 1
    fi
  else
    # Only meaningful once we know we're actually ON the integration
    # branch -- a dirty tracked tree elsewhere isn't this check's concern.
    # Warn-only (never blocks): a WIP tracked change on the integration
    # branch is a footgun worth flagging, not a reason to refuse the room.
    if ! git -C "$PWD" diff --quiet HEAD -- 2>/dev/null || ! git -C "$PWD" diff --cached --quiet -- 2>/dev/null; then
      echo "orc: WARNING -- tracked working tree is dirty on integration branch ($integration_branch);" \
        "commit or stash before building the room." >&2
    fi
  fi

  # issue #22: assert the inbox dirs dispatch.sh actually writes to exist,
  # rather than trusting a hand-made layout -- a fresh clone-per-project
  # room used to have NO seeding step at all, so dispatch.sh's own
  # "no inbox for agent" guard hard-failed the first time anything dispatched
  # to an agent nobody had mkdir'd by hand. This is the live agent-name set
  # dispatch.sh's pane_for_agent/inbox_dir_name actually resolve to -- NOT
  # the `roles:` block above, whose keys (implementer/tester/reviewer) name
  # a different axis (per-role model config) than these fixed dispatch
  # identities. No legacy `copilot` dir: inbox_dir_name() now aliases it
  # INTO scribe/, so scribe/ alone is the one live physical directory.
  mkdir -p ./.harness/inbox/orchestra ./.harness/inbox/builder \
    ./.harness/inbox/agy ./.harness/inbox/scribe

  # issue #89: pane 3 (copilot/scribe) retired -- no recurring scribe
  # job remains after #85 (Builder writes PR bodies, watch.sh closes issues
  # mechanically), so scribe becomes an on-demand headless spawn
  # (dispatch.sh's assign/handoff to 'scribe', see nudge_agent) instead of a
  # standing pane. 5 panes now, not 6: orchestra, builder, agy, gatekeeper,
  # watch.
  #
  # issue #87: an even `tiled` 5-way split squeezed the 3 INTERACTIVE agent
  # panes (orchestra/builder/agy) down to ~18 rows on a real terminal --
  # not enough headroom for Claude Code's own status line + input box +
  # scrollback, so the input line gets squeezed to nothing ("no space to
  # type", live-reported repeatedly, and plausibly a contributor to the
  # separate nudge-stranding issues). gatekeeper/watch are read-only
  # dashboards that tolerate a short strip; the agent panes do not.
  # Reserves a fixed MONITOR_ROWS-tall bottom strip for gatekeeper+watch
  # and gives the agent row everything else, computed from the REAL
  # calling terminal's size via `tput` -- queried BEFORE any tmux client
  # exists, so this scales with whatever terminal `orc up` is actually run
  # from rather than a fixed cell count. ORC_TERM_COLS/ORC_TERM_LINES
  # override tput outright (tests: deterministic sizing without a real
  # controlling tty).
  #
  # Split TARGETS (0, then 0.0 twice, then 0.3) are unchanged from before
  # this fix -- empirically verified (tmux list-panes geometry) that this
  # exact sequence assigns indices 0/1/2/3/4 to top-left/top-mid/top-right/
  # bottom-left/bottom-right respectively, matching the index->role
  # contract (AGENTS.md: 0=orchestra 1=builder 2=agy 3=gatekeeper
  # 4=watch; dispatch.sh's pane_for_agent and gatekeeper-liveness's watch
  # target both hardcode these positions) -- only the SIZE arguments and
  # the trailing `select-layout tiled` (which discarded them) changed.
  #
  # Falls back to a PERCENT-proportioned build of the SAME 3-top/2-bottom
  # shape, loudly (never silently), on a terminal too small (or
  # undetectable) to give the agent row a floor of
  # MIN_AGENT_ROWS. The fallback used to finish with `select-layout
  # tiled`, which REARRANGES the 5 panes into a 2+2+1 grid -- orchestra/
  # builder on top, agy/gatekeeper mid, watch full-width bottom -- so any
  # run that hit the fallback (e.g. `orc up` driven through a pipe or an
  # agent, where stdout is no tty) silently abandoned the row structure
  # the room contract draws (live-hit twice: 2026-07-22 diagnosis and
  # again on the 2026-07-23 rebuild). Percent sizes (`-l N%`, verified on
  # tmux 3.4 + 3.7b in the #87 round -- unlike `-p`, see below) need no
  # real terminal size, and tmux rescales the layout proportionally when
  # a client attaches, so the fallback now degrades only in SIZING
  # fidelity, never in shape. An `-l`/`-p` split size that would be non-positive is
  # a hard tmux error, not a soft clamp, so this must be decided BEFORE
  # issuing any split, not discovered from a failed command.
  # review round 2 (agy, CI-only failure on the Linux runner, reproduced
  # locally via Docker + Ubuntu 24.04's tmux 3.4): `-p <percent>` on
  # split-window fails outright ("size missing") on tmux 3.4, even though
  # it works fine on this dev machine's tmux 3.7b -- a real cross-version
  # behavior gap, not a typo. `-l <percent>%` and plain absolute `-l
  # <cells>` both work on every tmux version tested; switched to absolute
  # cell counts computed in shell (portable everywhere, no version-
  # dependent flag syntax at all).
  #
  # Also (round 2): `tput cols`/`tput lines` does NOT reliably fail when
  # stdout isn't a real terminal -- reproduced live, with TERM set (even
  # TERM=dumb) but no controlling tty, tput happily returns a plausible-
  # looking "80"/"24" fallback instead of erroring, which would otherwise
  # be trusted as "the actual client size" (this specific 80x24 case is
  # already caught by the row-count floor below, but that's incidental --
  # any other non-tty default that happened to number-check would not be
  # caught the same way). Gated explicitly: tput's numbers are only
  # trusted when stdout is a REAL tty; otherwise (and with no
  # ORC_TERM_COLS/LINES override) this always falls through to the loud
  # tiled fallback rather than gambling on what a non-tty default means.
  local term_cols term_lines monitor_rows=14 min_agent_rows=15 agent_rows
  local col_width half_width client_size
  if [ -n "${ORC_TERM_COLS:-}" ] && [ -n "${ORC_TERM_LINES:-}" ]; then
    term_cols="$ORC_TERM_COLS"
    term_lines="$ORC_TERM_LINES"
  elif [ -n "${TMUX:-}" ] && client_size="$(tmux display-message -p '#{client_width} #{client_height}' 2>/dev/null)" && [[ "$client_size" =~ ^[0-9]+\ [0-9]+$ ]]; then
    # issue #119: `orc up` run from INSIDE an already-attached tmux client
    # (a human's outer terminal is itself a tmux pane) measures the
    # CALLING PANE's own geometry via tput below, not the actual physical
    # terminal window -- live-hit rebuilding this room's own #87 layout,
    # where the calling pane was narrower than the real attached client,
    # tripping the loud tiled fallback for no real reason. Size from the
    # attached CLIENT instead whenever $TMUX is set (ORC_TERM_COLS/LINES
    # above still wins outright).
    #
    # agy review round 1 (PR #123): a session with NO attached client (the
    # exact case this fallthrough needs to handle) doesn't make
    # `#{client_width} #{client_height}` print nothing -- confirmed live,
    # tmux prints a single space + newline instead. A bare `[ -n
    # "$client_size" ]` treated that as success, then `${client_size%%
    # *}`/`${client_size##* }` on " " both yield EMPTY strings, and the
    # numeric comparisons below then threw a raw "integer expression
    # expected" to stderr instead of falling through cleanly. Anchored
    # regex requires two actual positive integers -- a lone space (or any
    # other non-numeric noise) now falls through to the tput/none chain
    # below, same as genuinely empty output.
    term_cols="${client_size%% *}"
    term_lines="${client_size##* }"
    echo "orc: sizing room at ${term_cols}x${term_lines} (source: attached tmux client)"
  elif [ -t 1 ]; then
    term_cols="$(tput cols 2>/dev/null || echo 0)"
    term_lines="$(tput lines 2>/dev/null || echo 0)"
  else
    term_cols=0
    term_lines=0
  fi
  agent_rows=$(( term_lines - monitor_rows - 1 ))  # -1: the divider row between the agent row and the monitor row

  if [ "$term_cols" -gt 0 ] && [ "$term_lines" -gt 0 ] && [ "$agent_rows" -ge "$min_agent_rows" ]; then
    tmux new-session -d -s "$session" -n main -x "$term_cols" -y "$term_lines"
    tmux rename-window -t "$session:main" "control-room"
    tmux set -t "$session:0" pane-border-status top

    col_width=$(( term_cols / 3 ))
    half_width=$(( term_cols / 2 ))
    tmux split-window -v -l "$monitor_rows" -t "$session:0"
    tmux split-window -h -l "$col_width" -t "$session:0.0"
    tmux split-window -h -l "$col_width" -t "$session:0.0"
    tmux split-window -h -l "$half_width" -t "$session:0.3"
  else
    # review round 2: ALWAYS warn on this branch, even when the size is
    # totally unknown (0x0 -- no tty, no override) rather than merely
    # measured-too-small. An earlier draft only warned when term_lines was
    # a real positive number, silently skipping the message for the
    # unknown-size case -- exactly backwards from "loud, never silent"
    # (found live: no-tty + no-override took this branch with NO warning
    # at all).
    local size_desc="${term_cols}x${term_lines}"
    if [ "$term_cols" -le 0 ] || [ "$term_lines" -le 0 ]; then
      size_desc="unknown (no tty, no ORC_TERM_COLS/LINES override)"
    fi
    echo "orc: WARNING -- terminal size ${size_desc} -- too small (or undetectable) for the weighted agent-panes layout (need >= ${min_agent_rows} rows for the agent panes after reserving ${monitor_rows} for the monitor row) -- falling back to percent-proportioned sizing (same 3-top/2-bottom shape, guessed sizes). Agent panes will be short; resize your terminal and restart the room ('orc up' again after killing the session) for more headroom." >&2
    tmux new-session -d -s "$session" -n main
    tmux rename-window -t "$session:main" "control-room"
    tmux set -t "$session:0" pane-border-status top

    # Same split TARGETS as the weighted branch (index->role contract),
    # sized in percent of the pane being split: 25% bottom strip, then
    # 33% + 50%-of-the-remainder = three equal top columns, then a half
    # split for the monitor pair. NO trailing select-layout -- that is
    # what used to discard this shape.
    tmux split-window -v -l 25% -t "$session:0"
    tmux split-window -h -l 33% -t "$session:0.0"
    tmux split-window -h -l 50% -t "$session:0.0"
    tmux split-window -h -l 50% -t "$session:0.3"

    # The percent guesses above rescale UNPREDICTABLY when the first real
    # client attaches -- observed live on both 2026-07-23 rebuilds: the
    # 25% strip landed at 23 of 59 rows (agents squeezed to 35) and the
    # monitor strip had to be resize-pane'd back down by hand. tmux DOES
    # learn the real terminal size the moment a client attaches, so arm a
    # ONE-SHOT client-attached hook that snaps the monitor strip to the
    # same absolute monitor_rows the weighted branch uses. Two non-obvious
    # choices, both verified empirically:
    #   - `run-shell -b`, NOT a direct resize-pane in the hook: the hook
    #     fires BEFORE tmux rescales the window to the attaching client,
    #     so an inline resize gets mangled by the rescale that follows it;
    #     a backgrounded shell re-enters the server AFTER the attach
    #     transaction completes (measured: strip 31 inline vs 14 via -b).
    #   - self-unsetting (`set-hook -u` in the same hook value): one
    #     attach makes one sizing decision, so later re-attaches and
    #     manual live pane tuning are never fought by a leftover hook.
    # The resize is guarded to clients tall enough to keep the SAME
    # min_agent_rows floor the weighted branch enforces; on a shorter (or
    # unreadable -- the [ ] error is squelched, test goes false) client
    # the percent proportions stand, and the hook still disarms.
    tmux set-hook -t "$session" client-attached "run-shell -b 'if [ \"#{client_height}\" -ge $(( monitor_rows + min_agent_rows + 1 )) ] 2>/dev/null; then tmux resize-pane -t $session:0.3 -y $monitor_rows; fi' ; set-hook -u -t \"$session\" client-attached"
  fi

  tmux select-pane -t "$session:0.0" -T "orchestra"
  tmux select-pane -t "$session:0.1" -T "builder"
  tmux select-pane -t "$session:0.2" -T "agy"
  tmux select-pane -t "$session:0.3" -T "gatekeeper"
  tmux select-pane -t "$session:0.4" -T "pr/budget watch"

  if [ "${ORC_SKIP_PANE_COMMANDS:-0}" != "1" ]; then
    # issue #50: ORC_ROLE=<role> prefixed on each pane's OWN launch command
    # (not `tmux send-keys ... export ...` as a separate step -- this must
    # be in the SAME process `claude` itself is exec'd from, so every hook
    # subprocess Claude Code spawns inherits it via ordinary environment
    # inheritance). hooks/check-handoff.sh reads this to gate the
    # handoff.md nag to Orchestra only -- a pane with no ORC_ROLE (a
    # session started outside this room) is correctly treated as unknown,
    # never nagged. agy isn't a Claude Code session, but it now participates
    # in native hooks, so it gets ORC_ROLE=agy.
    tmux send-keys -t "$session:0.0" "$(sl_build_launch_cmd orchestra "$orchestra_model" --dangerously-skip-permissions)" C-m
    tmux send-keys -t "$session:0.1" "$(sl_build_launch_cmd builder "$implementer_model" --dangerously-skip-permissions)" C-m
    tmux send-keys -t "$session:0.2" 'ORC_ROLE=agy agy --dangerously-skip-permissions' C-m
    # issue #105 Task 3: the supervisor respawns gatekeeper.sh with bounded
    # backoff if it ever exits, instead of leaving pane 3 with a dead
    # process until a human notices.
    tmux send-keys -t "$session:0.3" "$ORC_LIB_DIR/gatekeeper-supervisor.sh" C-m
    tmux send-keys -t "$session:0.4" "$ORC_LIB_DIR/watch.sh" C-m
  fi

  # Gatekeeper liveness watchdog: independent process, not a pane in
  # the main session, so a gatekeeper crash/hang can't also silence its own
  # warning. Log lands in THIS clone's own state dir (./.harness/state,
  # cwd-relative -- clone-per-project means there's no shared install to
  # clobber).
  #
  # issue #59: this used to be `nohup ... &`, which guard.sh correctly
  # fails closed on (nohup is an opaque executor it can't safely inspect
  # for a hidden write, same posture as eval/sudo/env -- see guard.sh's
  # leading_verb check) -- and did so MID-DRILL, after the other three
  # loops had already been killed, which is the worst possible moment to
  # discover a restart path doesn't work. A detached tmux session launched
  # the SAME way as the other three loops (gatekeeper-supervisor/watch, via
  # `tmux send-keys`) is fully inspectable and needs no special-casing here
  # -- `${session}-liveness` so two clone-per-project rooms never collide
  # on a shared session name (issue #19's own reasoning, applied here).
  # `-c "$PWD"` reproduces nohup's cwd-preserving behavior: gatekeeper-
  # liveness.sh resolves its project root from $PWD at launch time.
  if [ "${ORC_SKIP_LIVENESS:-0}" != "1" ]; then
    mkdir -p ./.harness/state
    local liveness_session="${session}-liveness"
    tmux kill-session -t "$liveness_session" 2>/dev/null || true
    tmux new-session -d -s "$liveness_session" -c "$PWD"
    tmux send-keys -t "$liveness_session" \
      "$ORC_LIB_DIR/gatekeeper-liveness.sh >> ./.harness/state/gatekeeper-liveness.log 2>&1" C-m
  fi

  # issue #18 item 5 (C1): seed merge-watch-state on a fresh room so
  # watch.sh's merge-watch doesn't replay comment+close on every already-
  # merged PR and fire a stale "PICK next" nudge. Idempotent (the helper
  # itself no-ops once the state file exists) and non-fatal (never aborts
  # `orc up` on a gh hiccup) -- safe to call unconditionally here, not just
  # on a literal first invocation.
  if [ "${ORC_SKIP_MERGE_WATCH_SEED:-0}" != "1" ]; then
    bash "$ORC_LIB_DIR/orc-seed-merge-watch.sh" || true
  fi

  # issue #10/#31: .claude/settings.json is a gitignored per-room artifact
  # -- a hand-assembled or drifted copy can silently omit a hook and
  # nothing catches it (exactly how the quota-stop-gate went un-wired for
  # this room's whole life). Non-fatal (a config problem `orc up` can't fix
  # itself shouldn't block the room from starting) but LOUD: the check
  # itself writes an explicit WARNING to stderr on any omission, so this
  # can't rot unseen the way #10 did.
  if [ "${ORC_SKIP_HOOK_WIRING_CHECK:-0}" != "1" ]; then
    bash "$ORC_LIB_DIR/check-hook-wiring.sh" ./.claude/settings.json || true
  fi

  tmux select-pane -t "$session:0.0"

  echo "orc up: project=$project integration_branch=$integration_branch" \
    "orchestra_model=$orchestra_model implementer_model=$implementer_model" \
    "protected_paths=$(orc_protected_paths | paste -sd, -)" >&2
}

orc_up() {
  local session="$ORC_SESSION"
  if tmux has-session -t "$session" 2>/dev/null; then
    exec tmux attach -t "$session"
  fi
  orc_build_session
  exec tmux attach -t "$session"
}

# --- orc init (issue #5): per-project onboarding wizard --------------
# Non-interactive core (orc_init_core) does the actual work from a flat
# KEY=value answers file; the interactive wrapper (orc_init_interactive)
# only prompts for the same keys and writes an equivalent answers file
# before calling the core. Tests drive the core directly.
#
# --force (issue #116, Gate-1 plan on the issue) resyncs an EXISTING
# room's templates-derived files (AGENTS.md/CLAUDE.md/GEMINI.md/souls/*/
# skill pack/.claude/settings.json/.agents/hooks.json) against the
# CURRENT templates, backing up any hand-edited file first (drift is
# detected against .harness/state/init-manifest, a sha256 baseline
# written at every init/--force -- no manifest at all means a pre-#116
# project, treated conservatively as all-drifted). orchestrator.yaml
# itself is only rewritten when --force is paired with an explicit
# --answers file; bare --force reads it as the answers source instead.
# See orc_init_force below; orc_init_core (this function) stays the
# fresh-room path only. Likewise "orc up --dry-run" doesn't exist (orc up
# takes no flags at all yet) -- not added here; post-init verification
# instead reuses the two static verifiers this repo already has
# (check-hook-wiring.sh, orc-install-skills --check).
ORC_TEMPLATES_DIR="$ORC_SCRIPT_DIR/../templates"

# orc_init_read_answer <answers_file> <key> [default] -- a KEY=value line
# reader, not `source` -- so a malformed/adversarial answers file can
# never execute arbitrary shell (same "no eval'd input" posture as
# orc-config.sh's own yaml reader). A later duplicate key wins, matching
# ordinary shell-assignment semantics.
orc_init_read_answer() {
  local file="$1" key="$2" default="${3:-}" val
  val="$(awk -F'=' -v k="$key" '$1 == k { sub(/^[^=]*=/, ""); v = $0 } END { print v }' < "$file" 2>/dev/null)"
  echo "${val:-$default}"
}

# orc_init_validate <answers_file> -- ALL validation up front, before any
# write (issue #5 constraint: garbage answers must fail loud pre-write,
# never a half-room). Reports every problem found, not just the first,
# so a bad answers file only needs one fix-and-retry cycle.
orc_init_validate() {
  local file="$1" errors=0
  local project branch pct paths key model role

  project="$(orc_init_read_answer "$file" PROJECT)"
  if [ -z "$project" ]; then
    echo "orc init: PROJECT is required and was empty" >&2
    errors=1
  fi

  branch="$(orc_init_read_answer "$file" INTEGRATION_BRANCH main)"
  if ! git check-ref-format --branch "$branch" >/dev/null 2>&1; then
    echo "orc init: INTEGRATION_BRANCH '$branch' is not a valid git branch name" >&2
    errors=1
  fi

  for key in BUDGET_CLAUDE_PCT BUDGET_AGY_PCT; do
    pct="$(orc_init_read_answer "$file" "$key" 80)"
    if ! [[ "$pct" =~ ^[0-9]+$ ]] || [ "$pct" -lt 0 ] || [ "$pct" -gt 100 ]; then
      echo "orc init: $key '$pct' must be an integer 0-100" >&2
      errors=1
    fi
  done

  paths="$(orc_init_read_answer "$file" PROTECTED_PATHS)"
  if [ -n "$paths" ]; then
    local path_arr=() p
    IFS=',' read -ra path_arr <<< "$paths"
    for p in "${path_arr[@]}"; do
      case "$p" in
        /*|*..*|"")
          echo "orc init: PROTECTED_PATHS entry '$p' is not a valid relative path" >&2
          errors=1
          ;;
      esac
    done
  fi

  for role in ORCHESTRA IMPLEMENTER TESTER REVIEWER SCRIBE; do
    model="$(orc_init_read_answer "$file" "ROLE_${role}_MODEL")"
    if [ -z "$model" ]; then
      echo "orc init: ROLE_${role}_MODEL is required and was empty" >&2
      errors=1
    fi
  done

  return "$errors"
}

# orc_init_render_agents_md <answers_file> <src> <dest> -- copies
# templates/AGENTS.md, regenerating the Roles table's 5 data rows from
# the answers (the only per-project substitution that table needs --
# effort is already fixed per role in the template, matching
# orchestrator.yaml's own role.effort defaults) and dropping the now-
# stale ">"-blockquote install instructions -- orc init does that
# copy-and-fill step automatically, so a human running it never needs
# them.
orc_init_render_agents_md() {
  local answers_file="$1" src="$2" dest="$3"
  local orchestra_model orchestra_fb implementer_model implementer_fb
  local tester_model tester_fb reviewer_tool reviewer_fb scribe_model scribe_fb
  local tracker in_blockquote=0 line

  # issue #5 FLAG ruling: tickets-location/human-gates answers shape
  # GENERATED AGENTS.md PROSE only, never new orchestrator.yaml keys --
  # schema is added together with its first consumer, never ahead of it
  # (issue #86 precedent: a decorative yaml key nothing reads is a bug).
  # Only the ticket-tracker choice has an obvious, well-motivated line to
  # customize (the PICK step's own wording); the Gate-approver name is
  # deliberately NOT baked in here -- AGENTS.md's "you approve"/"you
  # merge" language already generically and correctly addresses whoever
  # is running the harness, and naming one person would be a regression
  # against that (see orc_init_core's completion summary for where the
  # answer actually goes instead).
  tracker="$(orc_init_read_answer "$answers_file" TICKET_TRACKER gh-issues)"
  orchestra_model="$(orc_init_read_answer "$answers_file" ROLE_ORCHESTRA_MODEL)"
  orchestra_fb="$(orc_init_read_answer "$answers_file" ROLE_ORCHESTRA_FALLBACK none)"
  implementer_model="$(orc_init_read_answer "$answers_file" ROLE_IMPLEMENTER_MODEL)"
  implementer_fb="$(orc_init_read_answer "$answers_file" ROLE_IMPLEMENTER_FALLBACK none)"
  tester_model="$(orc_init_read_answer "$answers_file" ROLE_TESTER_MODEL)"
  tester_fb="$(orc_init_read_answer "$answers_file" ROLE_TESTER_FALLBACK none)"
  reviewer_tool="$(orc_init_read_answer "$answers_file" ROLE_REVIEWER_MODEL)"
  reviewer_fb="$(orc_init_read_answer "$answers_file" ROLE_REVIEWER_FALLBACK none)"
  scribe_model="$(orc_init_read_answer "$answers_file" ROLE_SCRIBE_MODEL)"
  scribe_fb="$(orc_init_read_answer "$answers_file" ROLE_SCRIBE_FALLBACK none)"

  : > "$dest"
  while IFS= read -r line; do
    case "$line" in
      '>'*) in_blockquote=1; continue ;;
    esac
    if [ "$in_blockquote" -eq 1 ] && [ -z "$line" ]; then
      in_blockquote=0
      continue
    fi
    if [ "$in_blockquote" -eq 1 ]; then
      continue
    fi
    case "$line" in
      '1. PICK: Orchestra picks the next issue from the current milestone.')
        if [ "$tracker" = "gh-issues" ] || [ -z "$tracker" ]; then
          echo "$line" >> "$dest"
        else
          printf '1. PICK: Orchestra picks the next ticket from the current milestone (tracked in %s, not GitHub issues).\n' "$tracker" >> "$dest"
        fi
        ;;
      '| Orchestra '*)   printf '| Orchestra   | %s | High    | %s |\n' "$orchestra_model" "$orchestra_fb" >> "$dest" ;;
      '| Implementer '*) printf '| Implementer | %s | Default | %s |\n' "$implementer_model" "$implementer_fb" >> "$dest" ;;
      '| Tester '*)      printf '| Tester      | %s | Default | %s |\n' "$tester_model" "$tester_fb" >> "$dest" ;;
      '| Reviewer '*)    printf '| Reviewer    | %s | High    | %s |\n' "$reviewer_tool" "$reviewer_fb" >> "$dest" ;;
      '| Scribe '*)      printf '| Scribe      | %s | Low     | %s |\n' "$scribe_model" "$scribe_fb" >> "$dest" ;;
      *) echo "$line" >> "$dest" ;;
    esac
  done < "$src"
}

# orc_init_render_project_doc <src> <dest> <project> -- copies a
# per-project doc template (CLAUDE.md/GEMINI.md), substituting every
# <PROJECT> placeholder and dropping the install blockquote (same
# reasoning as orc_init_render_agents_md above).
orc_init_render_project_doc() {
  local src="$1" dest="$2" project="$3" in_blockquote=0 line
  : > "$dest"
  while IFS= read -r line; do
    case "$line" in
      '>'*) in_blockquote=1; continue ;;
    esac
    if [ "$in_blockquote" -eq 1 ] && [ -z "$line" ]; then
      in_blockquote=0
      continue
    fi
    if [ "$in_blockquote" -eq 1 ]; then
      continue
    fi
    echo "${line//<PROJECT>/$project}" >> "$dest"
  done < "$src"
}

# orc_init_render_soul <src> <dest> <model> <effort> <pane> -- copies a
# templates/souls/<role>.md identity card, substituting <MODEL>/<EFFORT>/
# <PANE> from the SAME answers the Roles table (orc_init_render_agents_md)
# reads -- one source of model-lane truth, two renderings. Cards summarize
# and point at AGENTS.md; they carry no blockquote to strip (issue #12).
orc_init_render_soul() {
  local src="$1" dest="$2" model="$3" effort="$4" pane="$5" line
  : > "$dest"
  while IFS= read -r line; do
    line="${line//<MODEL>/$model}"
    line="${line//<EFFORT>/$effort}"
    line="${line//<PANE>/$pane}"
    echo "$line" >> "$dest"
  done < "$src"
}

# orc_init_render_orchestrator_yaml <answers_file> <dest> -- builds
# orchestrator.yaml's content from an answers file. Shared by
# orc_init_core's fresh-room write (wrapped in a noclobber TOCTOU guard
# there) and orc_init_force's --answers-driven full re-init (issue #116) --
# one source of yaml-shape truth for both paths. ticket_tracker joined the
# persisted scalars here: bare --force's own answers source IS this file,
# and TICKET_TRACKER is the one answer that changes generated prose
# (AGENTS.md's PICK line) -- without persisting it, a resync would
# silently regress a non-default tracker back to gh-issues. GATE_APPROVER/
# GITHUB_REMOTE stay out: neither is ever rendered into any file's content
# (GATE_APPROVER is a one-time stdout courtesy, GITHUB_REMOTE has no
# consumer at all), so there's nothing for --force to lose by not
# persisting them.
orc_init_render_orchestrator_yaml() {
  local answers_file="$1" dest="$2"
  local project branch paths tracker role rk model eff path_arr p
  project="$(orc_init_read_answer "$answers_file" PROJECT)"
  branch="$(orc_init_read_answer "$answers_file" INTEGRATION_BRANCH main)"
  paths="$(orc_init_read_answer "$answers_file" PROTECTED_PATHS)"
  tracker="$(orc_init_read_answer "$answers_file" TICKET_TRACKER gh-issues)"
  {
    echo "project: $project"
    echo "integration_branch: $branch"
    echo "ticket_tracker: $tracker"
    echo ""
    echo "protected_paths:"
    if [ -n "$paths" ]; then
      path_arr=()
      IFS=',' read -ra path_arr <<< "$paths"
      for p in "${path_arr[@]}"; do
        echo "  - $p"
      done
    fi
    echo ""
    echo "roles:"
    for role in orchestra implementer tester reviewer scribe; do
      rk="$(echo "$role" | tr '[:lower:]' '[:upper:]')"
      model="$(orc_init_read_answer "$answers_file" "ROLE_${rk}_MODEL")"
      eff="$(orc_init_read_answer "$answers_file" "ROLE_${rk}_EFFORT" default)"
      echo "  $role:"
      echo "    model: $model"
      echo "    effort: $eff"
    done
    echo ""
    echo "budgets:"
    echo "  claude:"
    echo "    failsafe_pct: $(orc_init_read_answer "$answers_file" BUDGET_CLAUDE_PCT 80)"
    echo "  agy:"
    echo "    failsafe_pct: $(orc_init_read_answer "$answers_file" BUDGET_AGY_PCT 80)"
  } > "$dest" 2>/dev/null
}

# orc_init_core <answers_file> <target_dir> -- the whole non-interactive
# wizard: validate, refuse if already initialized, write every file,
# install skills, run the post-init verifiers. Nothing is written unless
# validation passes in full.
orc_init_core() {
  local answers_file="$1" target="$2"

  if [ ! -f "$answers_file" ]; then
    echo "orc init: no such answers file: $answers_file" >&2
    return 1
  fi
  # agy PR #117 finding 1: `cd "$target"` with target="-" is bash's own
  # "cd to $OLDPWD" shorthand, matched on the LITERAL value regardless of
  # quoting -- silently redirecting every write to the wrong directory.
  # Verified `cd -- "-"` does NOT actually suppress this (bash's cd
  # builtin special-cases a bare "-" even after `--`); a relative target
  # forced through "./" does, since it's then no longer the exact string
  # "-". An absolute target is left alone -- prefixing an absolute path
  # with "./" produces a leading "..//" that this bash's cd fails to
  # resolve, confirmed live.
  case "$target" in
    /*) : ;;
    *) target="./$target" ;;
  esac
  mkdir -p -- "$target"
  target="$(cd -- "$target" && pwd)"

  # agy PR #117 finding 2: `-f` is false for a broken symlink (its target
  # doesn't exist), so a stale/broken orchestrator.yaml symlink at the
  # target would sail past this refusal check, and the write below would
  # then follow the symlink and land wherever it points. `-e` (follows
  # and requires the resolved target to exist) OR `-L` (true for ANY
  # symlink, broken or not) together catch every case: a real file, a
  # working symlink, and a broken one.
  if [ -e "$target/orchestrator.yaml" ] || [ -L "$target/orchestrator.yaml" ]; then
    echo "orc init: REFUSE -- $target/orchestrator.yaml already exists. Run 'orc init --force' to resync it instead." >&2
    return 1
  fi

  if ! orc_init_validate "$answers_file"; then
    echo "orc init: aborting -- fix the answers above and re-run. Nothing was written." >&2
    return 1
  fi

  local project gate
  project="$(orc_init_read_answer "$answers_file" PROJECT)"
  gate="$(orc_init_read_answer "$answers_file" GATE_APPROVER "the human running this harness")"

  # agy PR #117 finding 3: TOCTOU between the -e/-L refusal check above
  # and this write -- noclobber makes the write itself an atomic
  # create-only operation at the filesystem level, so a file that
  # appears in that window (a second orc init racing the same target)
  # fails the write instead of silently overwriting it. The actual yaml
  # content comes from orc_init_render_orchestrator_yaml (issue #116,
  # shared with --force's full-re-init path) -- this is just the
  # TOCTOU-safe write wrapper around it.
  set -o noclobber
  if ! orc_init_render_orchestrator_yaml "$answers_file" "$target/orchestrator.yaml"; then
    set +o noclobber
    echo "orc init: REFUSE -- $target/orchestrator.yaml appeared between the check above and this write (race with another orc init?). orc init never overwrites an already-initialized project." >&2
    return 1
  fi
  set +o noclobber

  orc_init_render_agents_md "$answers_file" "$ORC_TEMPLATES_DIR/AGENTS.md" "$target/AGENTS.md"
  orc_init_render_project_doc "$ORC_TEMPLATES_DIR/CLAUDE.md" "$target/CLAUDE.md" "$project"
  orc_init_render_project_doc "$ORC_TEMPLATES_DIR/GEMINI.md" "$target/GEMINI.md" "$project"

  cp "$ORC_TEMPLATES_DIR/review-protocol.md" "$target/review-protocol.md"

  # issue #12: per-role SOUL.md identity cards -- same model-lane answers
  # as the AGENTS.md Roles table above, one row of truth rendered twice.
  # Builder combines Implementer+Tester into one pane (see CLAUDE.md's own
  # Roles section) -- its soul takes the Implementer lane, the one
  # actually exec'd for that pane by orc_build_session. Scribe has no
  # pane (headless one-shot, issue #89) -- its <PANE> says so instead of a
  # tmux index.
  mkdir -p "$target/souls"
  orc_init_render_soul "$ORC_TEMPLATES_DIR/souls/orchestra.md" "$target/souls/orchestra.md" \
    "$(orc_init_read_answer "$answers_file" ROLE_ORCHESTRA_MODEL)" \
    "$(orc_init_read_answer "$answers_file" ROLE_ORCHESTRA_EFFORT high)" "0.0"
  orc_init_render_soul "$ORC_TEMPLATES_DIR/souls/builder.md" "$target/souls/builder.md" \
    "$(orc_init_read_answer "$answers_file" ROLE_IMPLEMENTER_MODEL)" \
    "$(orc_init_read_answer "$answers_file" ROLE_IMPLEMENTER_EFFORT default)" "0.1"
  orc_init_render_soul "$ORC_TEMPLATES_DIR/souls/reviewer.md" "$target/souls/reviewer.md" \
    "$(orc_init_read_answer "$answers_file" ROLE_REVIEWER_MODEL)" \
    "$(orc_init_read_answer "$answers_file" ROLE_REVIEWER_EFFORT high)" "0.2"
  orc_init_render_soul "$ORC_TEMPLATES_DIR/souls/scribe.md" "$target/souls/scribe.md" \
    "$(orc_init_read_answer "$answers_file" ROLE_SCRIBE_MODEL)" \
    "$(orc_init_read_answer "$answers_file" ROLE_SCRIBE_EFFORT low)" "headless (no standing pane)"

  # issue #12: agy has no SessionStart-hook equivalent we control (unlike
  # Claude's orchestra/builder panes) or a scribe-style spawn prompt to
  # ride in -- it's a standing interactive pane. Verified live (see
  # decisions.log): `.agents/rules/` is NOT a confirmed agy mechanism --
  # agy's own introspection found no documentation for it and could not
  # confirm it experimentally, contradicting the immuhammad/agent-
  # orchestra#8 research's self-inspection claim. GEMINI.md IS a
  # confirmed native mechanism (this project's own agy Reviewer pane has
  # operated on AGENTS.md/GEMINI.md content every session) and is already
  # per-project rendered with a "## Reviewer" section -- append the soul
  # card there instead of a speculative unverified path.
  {
    echo ""
    echo "## SOUL"
    echo ""
    cat "$target/souls/reviewer.md"
  } >> "$target/GEMINI.md"

  mkdir -p "$target/.harness"
  cp "$ORC_TEMPLATES_DIR/handoff.md" "$target/.harness/handoff.md"
  touch "$target/.harness/decisions.log"

  mkdir -p "$target/.claude"
  cp "$ORC_TEMPLATES_DIR/settings.json" "$target/.claude/settings.json"
  mkdir -p "$target/.agents"
  cp "$ORC_TEMPLATES_DIR/agents-hooks.json" "$target/.agents/hooks.json"

  bash "$ORC_SCRIPT_DIR/orc-install-skills" "$target"

  orc_init_write_manifest "$target"

  echo "orc init: wrote a new control room for '$project' at $target"
  echo "orc init: Gate 1/Gate 2 approver: $gate"

  local verify_failed=0
  if ! bash "$ORC_LIB_DIR/check-hook-wiring.sh" "$target/.claude/settings.json"; then
    verify_failed=1
  fi
  if ! bash "$ORC_SCRIPT_DIR/orc-install-skills" --check "$target"; then
    verify_failed=1
  fi
  if [ "$verify_failed" -eq 1 ]; then
    echo "orc init: WARNING -- the room was written but a post-init verifier failed above; something is wrong with this installation, not the answers you gave." >&2
    return 1
  fi
}

# orc_init_sha256 <path> -- portable content hash for issue #116's drift
# manifest. macOS ships shasum but not sha256sum by default; Linux CI has
# sha256sum. Prefer sha256sum when present (the common CI case) and fall
# back to shasum -a 256 otherwise.
orc_init_sha256() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    shasum -a 256 "$1" | awk '{print $1}'
  fi
}

# orc_init_manifest_targets -- the templates-derived paths issue #116's
# --force tracks for drift detection, one relative path per line.
# orchestrator.yaml is tracked too: --force + an explicit answers file
# fully rewrites it, and a hand-edited orchestrator.yaml deserves the same
# backup-first courtesy as everything else -- bare --force never reads or
# writes it regardless (see orc_init_force), so tracking it here doesn't
# widen bare --force's scope. The installed skill pack is NOT tracked:
# bin/orc-install-skills is already its own idempotent, unconditionally-
# overwriting install/prune tool (issue #8) -- re-running it is the
# established mechanism, not a manifest-driven one.
orc_init_manifest_targets() {
  printf '%s\n' \
    AGENTS.md CLAUDE.md GEMINI.md review-protocol.md \
    souls/orchestra.md souls/builder.md souls/reviewer.md souls/scribe.md \
    .claude/settings.json .agents/hooks.json orchestrator.yaml
}

# orc_init_manifest_path <target>
orc_init_manifest_path() {
  echo "$1/.harness/state/init-manifest"
}

# orc_init_write_manifest <target> -- (re)writes the sha256 manifest from
# whichever of orc_init_manifest_targets currently exists on disk. Run at
# the end of EVERY init/--force (fresh rooms get a baseline immediately,
# so their FIRST --force already has one to compare against -- only a
# genuinely pre-#116 project ever hits the missing-manifest fallback).
# Skips the rewrite when the computed content is byte-identical to what's
# already there: a --force run that changed nothing must not churn the
# manifest's own mtime either (issue #116's idempotence guarantee covers
# this file too, not just the tracked content files).
orc_init_write_manifest() {
  local target="$1" mpath tmp rel abs
  mpath="$(orc_init_manifest_path "$target")"
  mkdir -p "$(dirname "$mpath")"
  tmp="$(mktemp "$mpath.XXXXXX")"
  while IFS= read -r rel; do
    abs="$target/$rel"
    [ -f "$abs" ] || continue
    printf '%s  %s\n' "$(orc_init_sha256 "$abs")" "$rel" >> "$tmp"
  done < <(orc_init_manifest_targets)
  if [ -f "$mpath" ] && cmp -s "$tmp" "$mpath"; then
    rm -f "$tmp"
  else
    mv "$tmp" "$mpath"
  fi
}

# orc_init_manifest_hash <target> <relpath> -- the sha256 init-manifest
# recorded for relpath at its last write, or empty if untracked/no
# manifest at all. Empty is the MISSING-MANIFEST signal orc_init_apply_file
# treats as drifted by default (issue #116's conservative fallback for a
# pre-#116 project that never had a baseline to compare against).
orc_init_manifest_hash() {
  local target="$1" rel="$2" mpath
  mpath="$(orc_init_manifest_path "$target")"
  [ -f "$mpath" ] || return 0
  awk -v r="$rel" '$2 == r { print $1; exit }' "$mpath"
}

# orc_init_apply_file <target> <relpath> <new_content_path> <backup_rel>
# -- issue #116, always consumes new_content_path (moves it into place or
# discards it):
#   dest missing                                  -> plain write
#   dest present, hash matches init-manifest AND
#     matches the freshly rendered content          -> untouched entirely
#     (no write at all -- preserves mtime, the idempotence guarantee)
#   dest present, hash matches init-manifest BUT
#     differs from the freshly rendered content      -> plain overwrite
#     (template/answers changed upstream; nothing hand-edited to protect)
#   dest present, hash does NOT match init-manifest
#     (hand-edited since last generation, OR no
#      manifest entry at all -- conservative default) -> back up to
#     backup_rel first (LOUD, one line to stdout), then overwrite
orc_init_apply_file() {
  local target="$1" rel="$2" newpath="$3" backup_rel="$4"
  local dest="$target/$rel"
  mkdir -p "$(dirname "$dest")"

  if [ ! -e "$dest" ]; then
    mv "$newpath" "$dest"
    return 0
  fi

  local old_hash manifest_hash new_hash
  old_hash="$(orc_init_sha256 "$dest")"
  manifest_hash="$(orc_init_manifest_hash "$target" "$rel")"

  if [ -n "$manifest_hash" ] && [ "$old_hash" = "$manifest_hash" ]; then
    new_hash="$(orc_init_sha256 "$newpath")"
    if [ "$old_hash" = "$new_hash" ]; then
      rm -f "$newpath"
    else
      mv "$newpath" "$dest"
    fi
    return 0
  fi

  mkdir -p "$target/$backup_rel/$(dirname "$rel")"
  cp -p "$dest" "$target/$backup_rel/$rel"
  echo "orc init --force: DRIFT BACKUP -- $rel changed since it was last generated (hand-edited?) -- backed up to $backup_rel/$rel before overwriting"
  mv "$newpath" "$dest"
}

# orc_init_answers_from_yaml <target> <out_answers_file> -- issue #116:
# bare --force's answers source is the room's OWN orchestrator.yaml, not
# a fresh answers file -- reconstructs the same flat KEY=value shape
# orc_init_read_answer expects, via orc-config.sh's already-tested
# readers (the same round trip tests/orc-init.test.sh's own "orchestrator.
# yaml round-trips through orc-config.sh's own readers" case exercises).
# GATE_APPROVER/GITHUB_REMOTE have no recoverable value (see
# orc_init_render_orchestrator_yaml's comment) -- GATE_APPROVER falls
# back to its usual default, GITHUB_REMOTE is left empty; neither affects
# any generated file's content.
orc_init_answers_from_yaml() {
  local target="$1" out="$2"
  local ORC_CONFIG_FILE="$target/orchestrator.yaml"
  local rk lc
  {
    echo "PROJECT=$(orc_get_scalar project)"
    echo "INTEGRATION_BRANCH=$(orc_get_scalar integration_branch)"
    echo "TICKET_TRACKER=$(orc_get_scalar ticket_tracker)"
    echo "PROTECTED_PATHS=$(orc_protected_paths | paste -sd, -)"
    echo "GATE_APPROVER=the human running this harness"
    for rk in ORCHESTRA IMPLEMENTER TESTER REVIEWER SCRIBE; do
      lc="$(echo "$rk" | tr '[:upper:]' '[:lower:]')"
      echo "ROLE_${rk}_MODEL=$(orc_get_role_model "$lc")"
      echo "ROLE_${rk}_EFFORT=$(orc_get_role_effort "$lc")"
    done
    echo "BUDGET_CLAUDE_PCT=$(orc_get_budget_pct claude)"
    echo "BUDGET_AGY_PCT=$(orc_get_budget_pct agy)"
  } > "$out"
}

# orc_init_force <target> [explicit_answers_file] -- issue #116, Gate-1
# plan on the issue: the --force re-init/resync story. Precondition:
# target must ALREADY be an initialized room (has orchestrator.yaml) --
# --force resyncs an EXISTING room; a brand-new target still goes through
# plain `orc init`.
#
#   bare --force             -- resync the templates-derived set
#     (AGENTS.md/CLAUDE.md/GEMINI.md/souls/*/skill pack/.claude/
#     settings.json/.agents/hooks.json) using the room's OWN
#     orchestrator.yaml as the answers source (orc_init_answers_from_yaml).
#     orchestrator.yaml itself is out of scope entirely in this shape --
#     never read for drift, never rewritten, never backed up.
#   --force --answers FILE   -- the same resync, PLUS a full re-init of
#     orchestrator.yaml from FILE -- still drift-checked like everything
#     else (a hand-edited orchestrator.yaml gets backed up first).
#
# .harness/** stays untouched beyond this function's OWN bookkeeping
# (init-manifest, init-backups/): decisions.log, handoff.md, inbox/,
# rules.md, and every other pre-existing state/ entry are never targeted
# by any write this function makes.
#
# orc-protect (bin/orc-protect, kernel immutability on .claude/.agents/
# orchestrator.yaml) is lifted for the duration if the target is
# currently protected, and restored once the resync finishes -- the
# off->edit->on dance folded INTO --force itself, per the Gate-1 plan,
# rather than a FLAG-worthy collision.
orc_init_force() {
  local target="$1" explicit_answers="${2:-}"

  case "$target" in
    /*) : ;;
    *) target="./$target" ;;
  esac
  if [ ! -d "$target" ] || { [ ! -f "$target/orchestrator.yaml" ] && [ ! -L "$target/orchestrator.yaml" ]; }; then
    echo "orc init: REFUSE -- $target has no orchestrator.yaml yet. --force resyncs an EXISTING room; run plain 'orc init' to create a new one." >&2
    return 1
  fi
  target="$(cd -- "$target" && pwd)"

  if [ -n "$explicit_answers" ] && [ ! -f "$explicit_answers" ]; then
    echo "orc init: no such answers file: $explicit_answers" >&2
    return 1
  fi

  local answers_file="$explicit_answers" synth=""
  if [ -z "$answers_file" ]; then
    synth="$(mktemp)"
    orc_init_answers_from_yaml "$target" "$synth"
    answers_file="$synth"
  fi

  if ! orc_init_validate "$answers_file"; then
    [ -n "$synth" ] && rm -f "$synth"
    echo "orc init: aborting -- fix the answers above and re-run. Nothing was written." >&2
    return 1
  fi

  local was_protected=0
  if bash "$ORC_SCRIPT_DIR/orc-protect" status "$target" >/dev/null 2>&1; then
    was_protected=1
    echo "orc init --force: $target is orc-protect'd -- lifting immutability for the resync (restoring it once done)."
    bash "$ORC_SCRIPT_DIR/orc-protect" off "$target" >&2 || true
  fi

  local ts backup_rel project
  ts="$(date +%Y%m%d%H%M%S)"
  backup_rel=".harness/state/init-backups/$ts"
  project="$(orc_init_read_answer "$answers_file" PROJECT)"

  # orchestrator.yaml: only in scope with an explicit answers file (a
  # full re-init) -- bare --force leaves it alone entirely, per plan item 3.
  if [ -z "$synth" ]; then
    local new_yaml
    new_yaml="$(mktemp "$target/orchestrator.yaml.XXXXXX")"
    orc_init_render_orchestrator_yaml "$answers_file" "$new_yaml"
    orc_init_apply_file "$target" "orchestrator.yaml" "$new_yaml" "$backup_rel"
  fi

  local new_agents new_claude new_gemini new_review new_settings new_hooks
  local new_soul_orchestra new_soul_builder new_soul_reviewer new_soul_scribe

  new_agents="$(mktemp "$target/AGENTS.md.XXXXXX")"
  orc_init_render_agents_md "$answers_file" "$ORC_TEMPLATES_DIR/AGENTS.md" "$new_agents"
  orc_init_apply_file "$target" "AGENTS.md" "$new_agents" "$backup_rel"

  new_claude="$(mktemp "$target/CLAUDE.md.XXXXXX")"
  orc_init_render_project_doc "$ORC_TEMPLATES_DIR/CLAUDE.md" "$new_claude" "$project"
  orc_init_apply_file "$target" "CLAUDE.md" "$new_claude" "$backup_rel"

  mkdir -p "$target/souls"
  new_soul_orchestra="$(mktemp "$target/souls/orchestra.md.XXXXXX")"
  orc_init_render_soul "$ORC_TEMPLATES_DIR/souls/orchestra.md" "$new_soul_orchestra" \
    "$(orc_init_read_answer "$answers_file" ROLE_ORCHESTRA_MODEL)" \
    "$(orc_init_read_answer "$answers_file" ROLE_ORCHESTRA_EFFORT high)" "0.0"
  orc_init_apply_file "$target" "souls/orchestra.md" "$new_soul_orchestra" "$backup_rel"

  new_soul_builder="$(mktemp "$target/souls/builder.md.XXXXXX")"
  orc_init_render_soul "$ORC_TEMPLATES_DIR/souls/builder.md" "$new_soul_builder" \
    "$(orc_init_read_answer "$answers_file" ROLE_IMPLEMENTER_MODEL)" \
    "$(orc_init_read_answer "$answers_file" ROLE_IMPLEMENTER_EFFORT default)" "0.1"
  orc_init_apply_file "$target" "souls/builder.md" "$new_soul_builder" "$backup_rel"

  new_soul_reviewer="$(mktemp "$target/souls/reviewer.md.XXXXXX")"
  orc_init_render_soul "$ORC_TEMPLATES_DIR/souls/reviewer.md" "$new_soul_reviewer" \
    "$(orc_init_read_answer "$answers_file" ROLE_REVIEWER_MODEL)" \
    "$(orc_init_read_answer "$answers_file" ROLE_REVIEWER_EFFORT high)" "0.2"
  orc_init_apply_file "$target" "souls/reviewer.md" "$new_soul_reviewer" "$backup_rel"

  new_soul_scribe="$(mktemp "$target/souls/scribe.md.XXXXXX")"
  orc_init_render_soul "$ORC_TEMPLATES_DIR/souls/scribe.md" "$new_soul_scribe" \
    "$(orc_init_read_answer "$answers_file" ROLE_SCRIBE_MODEL)" \
    "$(orc_init_read_answer "$answers_file" ROLE_SCRIBE_EFFORT low)" "headless (no standing pane)"
  orc_init_apply_file "$target" "souls/scribe.md" "$new_soul_scribe" "$backup_rel"

  # GEMINI.md: base project-doc render + the reviewer soul appended under
  # a ## SOUL heading, same two-step composition orc_init_core's fresh
  # path uses -- reusing souls/reviewer.md's content we JUST wrote above
  # rather than rendering the reviewer soul a second time.
  new_gemini="$(mktemp "$target/GEMINI.md.XXXXXX")"
  orc_init_render_project_doc "$ORC_TEMPLATES_DIR/GEMINI.md" "$new_gemini" "$project"
  {
    echo ""
    echo "## SOUL"
    echo ""
    cat "$target/souls/reviewer.md"
  } >> "$new_gemini"
  orc_init_apply_file "$target" "GEMINI.md" "$new_gemini" "$backup_rel"

  new_review="$(mktemp "$target/review-protocol.md.XXXXXX")"
  cp "$ORC_TEMPLATES_DIR/review-protocol.md" "$new_review"
  orc_init_apply_file "$target" "review-protocol.md" "$new_review" "$backup_rel"

  mkdir -p "$target/.claude" "$target/.agents"
  new_settings="$(mktemp "$target/.claude/settings.json.XXXXXX")"
  cp "$ORC_TEMPLATES_DIR/settings.json" "$new_settings"
  orc_init_apply_file "$target" ".claude/settings.json" "$new_settings" "$backup_rel"

  new_hooks="$(mktemp "$target/.agents/hooks.json.XXXXXX")"
  cp "$ORC_TEMPLATES_DIR/agents-hooks.json" "$new_hooks"
  orc_init_apply_file "$target" ".agents/hooks.json" "$new_hooks" "$backup_rel"

  bash "$ORC_SCRIPT_DIR/orc-install-skills" "$target"

  orc_init_write_manifest "$target"

  if [ "$was_protected" -eq 1 ]; then
    bash "$ORC_SCRIPT_DIR/orc-protect" on "$target" >&2 || true
  fi

  [ -n "$synth" ] && rm -f "$synth"

  echo "orc init --force: resync complete for $target"
  if [ -d "$target/$backup_rel" ]; then
    echo "orc init --force: drifted files were backed up under $backup_rel"
  fi
}

# orc_init_interactive <target_dir> -- thin Q&A wrapper: prompts for the
# exact same keys orc_init_core reads, writes them to a throwaway answers
# file, then delegates. Not itself under test (issue #5: "tests drive the
# non-interactive core") -- correctness lives in orc_init_core /
# orc_init_validate, which the prompts here can't bypass.
orc_init_interactive() {
  local target="${1:-$PWD}" answers
  answers="$(mktemp)"

  echo "orc init: interactive setup for a new control room at $target"
  local project branch remote tracker paths gate
  read -r -p "Project name: " project
  read -r -p "Integration branch [main]: " branch
  read -r -p "GitHub remote (optional): " remote
  read -r -p "Where do tickets live? gh-issues/client-tracker [gh-issues]: " tracker
  read -r -p "Protected paths, comma-separated (optional): " paths
  read -r -p "Who approves Gate 1/Gate 2? [the human running this harness]: " gate

  echo "Role -> model lanes (press enter for the usual defaults):"
  local orchestra_model implementer_model tester_model reviewer_model scribe_model
  read -r -p "  Orchestra model [opus]: " orchestra_model
  read -r -p "  Implementer model [sonnet]: " implementer_model
  read -r -p "  Tester model [sonnet]: " tester_model
  read -r -p "  Reviewer tool [agy]: " reviewer_model
  read -r -p "  Scribe model [haiku]: " scribe_model

  local claude_pct agy_pct
  read -r -p "Claude quota failsafe % [80]: " claude_pct
  read -r -p "agy quota failsafe % [80]: " agy_pct

  {
    echo "PROJECT=$project"
    echo "INTEGRATION_BRANCH=${branch:-main}"
    echo "GITHUB_REMOTE=$remote"
    echo "TICKET_TRACKER=${tracker:-gh-issues}"
    echo "PROTECTED_PATHS=$paths"
    echo "GATE_APPROVER=${gate:-the human running this harness}"
    echo "ROLE_ORCHESTRA_MODEL=${orchestra_model:-opus}"
    echo "ROLE_ORCHESTRA_EFFORT=high"
    echo "ROLE_IMPLEMENTER_MODEL=${implementer_model:-sonnet}"
    echo "ROLE_IMPLEMENTER_EFFORT=default"
    echo "ROLE_TESTER_MODEL=${tester_model:-sonnet}"
    echo "ROLE_TESTER_EFFORT=default"
    echo "ROLE_REVIEWER_MODEL=${reviewer_model:-agy}"
    echo "ROLE_REVIEWER_EFFORT=high"
    echo "ROLE_SCRIBE_MODEL=${scribe_model:-haiku}"
    echo "ROLE_SCRIBE_EFFORT=low"
    echo "BUDGET_CLAUDE_PCT=${claude_pct:-80}"
    echo "BUDGET_AGY_PCT=${agy_pct:-80}"
  } > "$answers"

  orc_init_core "$answers" "$target"
  local status=$?
  rm -f "$answers"
  return "$status"
}

# BASH_SOURCE-guarded _main, same pattern as dispatch.sh/orc-worktree.sh:
# lets tests `source` this file for orc_build_session/orc_init_core
# without triggering the interactive `orc up`/`orc init` paths.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  case "${1:-}" in
    up) orc_up ;;
    init)
      shift
      force=0
      answers=""
      target=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --force) force=1; shift ;;
          --answers) answers="$2"; shift 2 ;;
          *) target="$1"; shift ;;
        esac
      done
      target="${target:-$PWD}"
      if [ "$force" -eq 1 ]; then
        orc_init_force "$target" "$answers"
      elif [ -n "$answers" ]; then
        orc_init_core "$answers" "$target"
      else
        orc_init_interactive "$target"
      fi
      ;;
    *)
      echo "usage: orc.sh up|init [--force] [--answers <file>] [target_dir]" >&2
      exit 1
      ;;
  esac
fi
